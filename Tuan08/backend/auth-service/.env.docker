# Auth Service - Docker Configuration
PORT=8081
HOST=0.0.0.0
NODE_ENV=production
SERVICE_NAME=user-service

# Database
MONGO_URI=mongodb://admin:password123@mongodb:27017/movie_db?authSource=admin

# Message Broker
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672

# JWT Configuration
JWT_SECRET=your-secure-secret-key-for-production
JWT_EXPIRY=24h

# CORS
CORS_ORIGIN=*
