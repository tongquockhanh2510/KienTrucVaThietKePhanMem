# API Gateway - Production/Docker Configuration
PORT=8080
HOST=0.0.0.0
NODE_ENV=production

# Service URLs - Multiple instances with load balancing
# Format: http://host1:port1,http://host2:port2,http://host3:port3
USER_SERVICE_URLS=http://user-service-1:8081,http://user-service-2:8081
MOVIE_SERVICE_URLS=http://movie-service-1:8082,http://movie-service-2:8082
BOOKING_SERVICE_URLS=http://booking-service-1:8083,http://booking-service-2:8083
