# Production Environment Configuration Template
# Copy this file to the appropriate location and update with your values
# NEVER commit this file with real credentials to version control

# ============================================
# API GATEWAY PRODUCTION CONFIG
# ============================================

# File: api-gateway/.env.production

# API Gateway Settings
PORT=8080
HOST=0.0.0.0
NODE_ENV=production

# Multiple Service Instances (Load Balanced)
# Replace with your actual machine IPs
USER_SERVICE_URLS=http://192.168.1.102:8081,http://192.168.1.102:8084,http://192.168.1.102:8087
MOVIE_SERVICE_URLS=http://192.168.1.103:8082,http://192.168.1.103:8085,http://192.168.1.103:8088
BOOKING_SERVICE_URLS=http://192.168.1.104:8083,http://192.168.1.104:8086,http://192.168.1.104:8089

# Logging
LOG_LEVEL=info

# ============================================
# USER SERVICE PRODUCTION CONFIG
# ============================================

# File: backend/auth-service/.env.production

PORT=8081
HOST=0.0.0.0
NODE_ENV=production
SERVICE_NAME=user-service
INSTANCE_ID=1

# Database - With proper credentials
MONGO_URI=mongodb://admin:YOUR_SECURE_PASSWORD@192.168.1.100:27017/movie_db?authSource=admin&ssl=true

# Message Broker
RABBITMQ_URL=amqp://rabbitmq_user:rabbitmq_password@192.168.1.100:5672

# JWT Configuration - Use strong, random secret
JWT_SECRET=YOUR_GENERATED_RANDOM_SECRET_KEY_MIN_32_CHARS
JWT_EXPIRY=24h

# CORS
CORS_ORIGIN=https://yourdomain.com

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=warn

# ============================================
# MOVIE SERVICE PRODUCTION CONFIG
# ============================================

# File: backend/Movie-service/.env.production

PORT=8082
HOST=0.0.0.0
NODE_ENV=production
SERVICE_NAME=movie-service
INSTANCE_ID=1

# Database
MONGO_URI=mongodb://admin:YOUR_SECURE_PASSWORD@192.168.1.100:27017/movie_db?authSource=admin&ssl=true

# CORS
CORS_ORIGIN=https://yourdomain.com

# Caching
CACHE_ENABLED=true
CACHE_TTL=3600

# Logging
LOG_LEVEL=warn

# ============================================
# BOOKING SERVICE PRODUCTION CONFIG
# ============================================

# File: backend/movie-booking/.env.production

PORT=8083
HOST=0.0.0.0
NODE_ENV=production
SERVICE_NAME=booking-service
INSTANCE_ID=1

# Database
MONGO_URI=mongodb://admin:YOUR_SECURE_PASSWORD@192.168.1.100:27017/movie_db?authSource=admin&ssl=true

# Message Broker
RABBITMQ_URL=amqp://rabbitmq_user:rabbitmq_password@192.168.1.100:5672

# Upstream Services
USER_SERVICE_URL=http://192.168.1.102:8081
MOVIE_SERVICE_URL=http://192.168.1.103:8082

# Request Timeout (milliseconds)
UPSTREAM_TIMEOUT_MS=10000

# CORS
CORS_ORIGINS=https://yourdomain.com

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=warn

# ============================================
# PRODUCTION DEPLOYMENT NOTES
# ============================================

# Security Recommendations:
# 1. Generate strong JWT secrets:
#    node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#
# 2. Use environment variable management:
#    - HashiCorp Vault
#    - AWS Secrets Manager
#    - Azure Key Vault
#    - GitHub Secrets
#
# 3. Enable SSL/TLS:
#    - Install SSL certificates
#    - Enable HTTPS on all endpoints
#    - Use HSTS headers
#
# 4. MongoDB Security:
#    - Enable authentication
#    - Use strong passwords
#    - Implement role-based access control
#    - Enable SSL/TLS for connections
#
# 5. RabbitMQ Security:
#    - Change default credentials
#    - Disable guest account
#    - Enable SSL/TLS
#    - Use VLAN isolation
#
# 6. Network Security:
#    - Use VPC/Private networks
#    - Configure firewalls
#    - Use VPN for management
#    - Implement DDoS protection
#
# 7. Monitoring:
#    - Setup ELK stack for logging
#    - Configure Prometheus for metrics
#    - Setup Grafana for dashboards
#    - Configure alerting rules
#
# 8. Backup & Recovery:
#    - Daily MongoDB backups
#    - Test restore procedures
#    - Keep backups in separate location
#    - Implement point-in-time recovery
#
# 9. Load Balancing:
#    - Use external load balancer (HAProxy, Nginx, AWS ELB)
#    - Configure health checks
#    - Enable session persistence if needed
#    - Monitor load distribution
#
# 10. Scaling:
#    - Start with 2-3 instances per service
#    - Monitor metrics
#    - Add instances as needed
#    - Consider auto-scaling

# IP Address Mapping Example:
# Machine 1 (Infrastructure):
#   - MongoDB: 192.168.1.100:27017
#   - RabbitMQ: 192.168.1.100:5672
#
# Machine 2 (API Gateway + User Service):
#   - API Gateway: 192.168.1.102:8080
#   - User Service 1: 192.168.1.102:8081
#   - User Service 2: 192.168.1.102:8084
#   - User Service 3: 192.168.1.102:8087
#
# Machine 3 (Movie Service):
#   - Movie Service 1: 192.168.1.103:8082
#   - Movie Service 2: 192.168.1.103:8085
#   - Movie Service 3: 192.168.1.103:8088
#
# Machine 4 (Booking Service):
#   - Booking Service 1: 192.168.1.104:8083
#   - Booking Service 2: 192.168.1.104:8086
#   - Booking Service 3: 192.168.1.104:8089

# Deployment Verification Checklist:
# [ ] All services are running and healthy
# [ ] Database connectivity verified
# [ ] Message broker connectivity verified
# [ ] Load balancing working (test round-robin)
# [ ] SSL/TLS certificates installed
# [ ] Firewall rules configured
# [ ] Backup systems operational
# [ ] Monitoring and logging active
# [ ] Security scanning completed
# [ ] Performance baseline established
# [ ] Disaster recovery plan tested
# [ ] Documentation updated
