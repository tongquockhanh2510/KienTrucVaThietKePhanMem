# Booking Service - Docker Configuration
PORT=8083
HOST=0.0.0.0
NODE_ENV=production
SERVICE_NAME=booking-service

# Database
MONGO_URI=mongodb://admin:password123@mongodb:27017/movie_db?authSource=admin

# Message Broker
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672

# Upstream Services
USER_SERVICE_URL=http://user-service-1:8081
MOVIE_SERVICE_URL=http://movie-service-1:8082

# Timeout
UPSTREAM_TIMEOUT_MS=5000

# CORS
CORS_ORIGINS=*
